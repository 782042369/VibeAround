{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeWbz",
  "version": "0.7.5",
  "identifier": "com.vibewbz.app",
  "build": {
    "beforeDevCommand": "node ../scripts/link-sdk.mjs --mode=local && bun run --cwd ../desktop-ui dev",
    "devUrl": "http://localhost:5181",
    "beforeBuildCommand": "node ../scripts/link-sdk.mjs --mode=release && bun run --cwd ../desktop-ui build",
    "frontendDist": "../desktop-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "VibeWbz",
        "url": "/",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        },
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/startkit/**/*",
      "icons/32x32.png"
    ],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "Desktop launcher for Claude and Codex tools",
    "longDescription": "Desktop setup and launch tool for Claude Code, Codex CLI, Claude Desktop, and Codex Desktop.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "windows": {}
  },
  "plugins": {}
}
