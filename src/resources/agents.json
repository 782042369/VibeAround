[
  {
    "id": "claude",
    "display_name": "Claude Code",
    "description": "Anthropic Claude Code",
    "aliases": ["claude", "claude-code"],
    "install": { "type": "npm" },
    "acp": {
      "program": "claude"
    },
    "pty": {
      "command": "claude code --permission-mode acceptEdits"
    },
    "global_config": {
      "settings_path": ".claude.json",
      "settings_path_legacy": ".claude/settings.json",
      "mcp_key": "mcpServers",
      "mcp_entry": { "type": "http", "url": "{mcp_url}" },
      "skill_dir": ".claude/skills/agent-collaboration"
    }
  },
  {
    "id": "claude-desktop",
    "display_name": "Claude Desktop",
    "description": "Anthropic Claude desktop app",
    "aliases": ["claude-desktop", "claude-app"],
    "platforms": ["macos", "windows"],
    "direct_only": true,
    "download_urls": {
      "windows_x64": "https://claudeapp.agentsmirror.com/latest/win-x64",
      "windows_arm64": "https://claudeapp.agentsmirror.com/latest/win-arm64",
      "macos_x64": "https://claudeapp.agentsmirror.com/latest/mac",
      "macos_aarch64": "https://claudeapp.agentsmirror.com/latest/mac"
    },
    "acp": {
      "program": ""
    },
    "pty": {
      "command": "open -a Claude",
      "platform_commands": {
        "macos": "open -a Claude",
        "windows": "Start-Process Claude"
      }
    }
  },
  {
    "id": "codex",
    "display_name": "Codex CLI",
    "description": "OpenAI Codex CLI",
    "aliases": ["codex", "openai-codex"],
    "install": { "type": "npm" },
    "acp": {
      "program": "codex"
    },
    "pty": {
      "command": "codex"
    },
    "global_config": {
      "settings_path": ".codex/config.toml",
      "settings_format": "toml",
      "mcp_key": "mcp_servers",
      "mcp_entry": { "url": "{mcp_url}" },
      "skill_dir": ".codex/skills/agent-collaboration",
      "project_skill_dir": ".agents/skills/agent-collaboration"
    }
  },
  {
    "id": "codex-desktop",
    "display_name": "Codex Desktop",
    "description": "OpenAI Codex desktop app",
    "aliases": ["codex-desktop", "codex-app"],
    "platforms": ["macos", "windows"],
    "direct_only": true,
    "download_urls": {
      "windows_x64": "https://codexapp.agentsmirror.com/latest/win",
      "windows_arm64": "https://codexapp.agentsmirror.com/latest/win",
      "macos_x64": "https://codexapp.agentsmirror.com/latest/mac-intel",
      "macos_aarch64": "https://codexapp.agentsmirror.com/latest/mac-arm64"
    },
    "acp": {
      "program": ""
    },
    "pty": {
      "command": "open -a Codex",
      "platform_commands": {
        "macos": "open -a Codex",
        "windows": "Start-Process Codex"
      }
    }
  }
]
